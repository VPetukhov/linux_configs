#!/usr/bin/env bash
set -euo pipefail

# Image name (auto-built on first run)
IMAGE="${CLAUDE_DOC_IMAGE:-claude-doc:latest}"

# Persisted Claude state on the host. Inside the container this becomes HOME,
# so Claude can store both ~/.claude/ and ~/.claude.json in one place.
STATE_DIR="${CLAUDE_DOC_STATE_DIR:-$HOME/.claude-doc}"
STATE_HOME_DIR="/state"
CLAUDE_CONFIG_DIR="${STATE_HOME_DIR}/.claude"

# YOLO mode default: 1 (enabled). Set CLAUDE_DOC_YOLO=0 to disable.
YOLO="${CLAUDE_DOC_YOLO:-1}"

# Install GSD support by default. Set CLAUDE_DOC_GSD=0 to skip syncing skills.
GSD="${CLAUDE_DOC_GSD:-1}"
GSD_SPEC="${CLAUDE_DOC_GSD_SPEC:-get-shit-done-cc@latest}"

usage() {
  cat <<'USAGE'
Usage:
  claude-doc --login
  claude-doc --update-image
  claude-doc /absolute/or/relative/path/to/project

Env vars:
  CLAUDE_DOC_IMAGE=claude-doc:latest      # override the docker image name
  CLAUDE_DOC_STATE_DIR=~/.claude-doc      # host dir that stores ~/.claude and ~/.claude.json
  CLAUDE_DOC_YOLO=1|0                     # default 1 (enabled), set 0 to disable
  CLAUDE_DOC_GSD=1|0                      # default 1, set 0 to skip GSD install/sync
  CLAUDE_DOC_GSD_SPEC=get-shit-done-cc@latest
                                         # npm spec used when building the image
USAGE
}

build_image() {
  local update="${1:-0}"
  local -a build_opts=(-t "$IMAGE" --build-arg "GSD_SPEC=$GSD_SPEC")

  if [[ "$update" == "1" ]]; then
    build_opts=(--pull --no-cache -t "$IMAGE" --build-arg "GSD_SPEC=$GSD_SPEC")
  fi

  docker build "${build_opts[@]}" - <<'DOCKERFILE'
FROM node:22-bookworm

# Basic dev tooling that Claude Code commonly needs in repos
RUN apt-get update && apt-get install -y --no-install-recommends \
      git openssh-client ca-certificates curl jq ripgrep bubblewrap \
      build-essential python3 python3-pip python3-venv python-is-python3 make \
    && rm -rf /var/lib/apt/lists/*

ENV VIRTUAL_ENV=/opt/claude-doc-python
ENV PATH="${VIRTUAL_ENV}/bin:${PATH}"

# Preinstall a small Python data-science/tooling stack.
# "statsbase" is not published on PyPI, so install statsmodels instead.
RUN python -m venv "${VIRTUAL_ENV}" \
    && pip install --no-cache-dir --upgrade pip \
    && pip install --no-cache-dir \
      click \
      matplotlib \
      pandas \
      plotly \
      scikit-learn \
      seaborn \
      statsmodels \
      tqdm

ARG GSD_SPEC=get-shit-done-cc@latest

# Install Claude Code and GSD from npm.
RUN npm i -g @anthropic-ai/claude-code "${GSD_SPEC}"

WORKDIR /work
DOCKERFILE
}

ensure_image() {
  if docker image inspect "$IMAGE" >/dev/null 2>&1; then
    return 0
  fi

  echo "Building $IMAGE (one-time)..." >&2
  build_image 0
}

update_image() {
  echo "Updating $IMAGE (pulling latest base image, Claude Code, and GSD)..." >&2
  build_image 1
}

host_abs_path() {
  local p="$1"
  if command -v realpath >/dev/null 2>&1; then
    realpath "$p"
  elif command -v readlink >/dev/null 2>&1; then
    readlink -f "$p" || printf "%s\n" "$p"
  else
    # best-effort
    (cd "$p" 2>/dev/null && pwd -P) || printf "%s\n" "$p"
  fi
}

common_run_args() {
  # shellcheck disable=SC2046
  cat <<ARGS
--rm --init -it
-e TERM=${TERM:-xterm-256color}
-e HOME=${STATE_HOME_DIR}
-e CLAUDE_CONFIG_DIR=${CLAUDE_CONFIG_DIR}
-e CLAUDE_DOC_IMAGE_ID=$(docker image inspect "$IMAGE" --format '{{.Id}}')
-v ${STATE_DIR}:${STATE_HOME_DIR}:rw
-u $(id -u):$(id -g)
--cap-drop=ALL
--security-opt=no-new-privileges
ARGS
}

container_bootstrap_script() {
  cat <<'SCRIPT'
mkdir -p "${HOME}" "${CLAUDE_CONFIG_DIR}"

if [[ "${CLAUDE_DOC_GSD:-1}" != "0" ]]; then
  gsd_marker="${HOME}/.claude-doc-gsd-image-id"
  gsd_image_id="${CLAUDE_DOC_IMAGE_ID:-}"
  gsd_needs_sync=1
  gsd_marker_id=""

  if [[ -n "$gsd_image_id" ]] && [[ -f "$gsd_marker" ]]; then
    if read -r gsd_marker_id <"$gsd_marker" && [[ "$gsd_marker_id" == "$gsd_image_id" ]]; then
      gsd_needs_sync=0
    fi
  fi

  if [[ "$gsd_needs_sync" == "1" ]]; then
    tmp_log="$(mktemp)"
    echo "Syncing Get Shit Done into ${CLAUDE_CONFIG_DIR}..." >&2
    if ! get-shit-done-cc --claude --global >"$tmp_log" 2>&1; then
      cat "$tmp_log" >&2
      rm -f "$tmp_log"
      exit 1
    fi
    rm -f "$tmp_log"

    if [[ -n "$gsd_image_id" ]]; then
      tmp_marker="$(mktemp)"
      printf '%s\n' "$gsd_image_id" >"$tmp_marker"
      mv "$tmp_marker" "$gsd_marker"
    fi
  fi
fi
SCRIPT
}

main() {
  if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    usage
    exit 0
  fi

  mkdir -p "$STATE_DIR"

  if [[ $# -eq 1 && "$1" == "--login" ]]; then
    ensure_image
    docker run $(common_run_args) \
      -e CLAUDE_DOC_GSD="$GSD" \
      "$IMAGE" bash -lc \
      "$(container_bootstrap_script)
if claude auth status --json 2>/dev/null | jq -e '.loggedIn == true' >/dev/null 2>&1; then
  exec claude auth status --text
else
  echo 'Launching Claude Code interactive login...' >&2
  echo 'Complete onboarding and sign-in in the Claude UI.' >&2
  echo 'If you land in a normal prompt, type /login.' >&2
  exec claude /login
fi"
    exit 0
  fi

  if [[ $# -eq 1 && ( "$1" == "--update-image" || "$1" == "--update" ) ]]; then
    update_image
    exit 0
  fi

  if [[ $# -ne 1 ]]; then
    usage
    exit 2
  fi

  ensure_image

  local_dir="$(host_abs_path "$1")"
  if [[ ! -d "$local_dir" ]]; then
    echo "Not a directory: $local_dir" >&2
    exit 2
  fi

  docker run $(common_run_args) \
    -e CLAUDE_DOC_GSD="$GSD" \
    -e CLAUDE_DOC_YOLO="$YOLO" \
    -v "$local_dir":/work:rw -w /work \
    "$IMAGE" bash -lc "$(container_bootstrap_script)
      if [[ \"\${CLAUDE_DOC_YOLO:-1}\" != \"0\" ]]; then
        exec claude --dangerously-skip-permissions
      else
        exec claude
      fi
    "
}

main "$@"
